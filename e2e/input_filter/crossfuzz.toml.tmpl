[campaign]
name = "input_filter_test"
timeout = "{{or .CampaignTimeout "30m"}}"
exec_timeout = "500ms"
max_input_size = 64

[corpus]
seed_dir = "./seeds"
corpus_dir = "./corpus"
findings_dir = "./findings"

# target_identity returns whatever input it sees.
[[target]]
name = "target_identity"
language = "go"
binary = "./identity/identity"
build_cmd = "cd identity && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o identity ."

# target_const always returns "ZZZZZZZZ" regardless of input. byte_equal
# diverges from target_identity on any non-"ZZZZZZZZ" input.
[[target]]
name = "target_const"
language = "go"
binary = "./constant/constant"
build_cmd = "cd constant && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o constant ."

[comparator]
type = "byte_equal"

{{if .UseFilter}}
[input_filter]
binary = "./{{.FilterDir}}/filter"
build_cmd = "cd {{.FilterDir}} && go build -o filter ."
transform = {{if .Transform}}true{{else}}false{{end}}
{{end}}
