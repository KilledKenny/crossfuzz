[campaign]
name = "compare_numeric"
timeout = "{{or .CampaignTimeout "30m"}}"
exec_timeout = "500ms"
max_input_size = 64

[corpus]
seed_dir = "./seeds"
corpus_dir = "./corpus"
findings_dir = "./findings"

[[target]]
name = "spaced"
language = "go"
binary = "./spaced/spaced"
build_cmd = "cd spaced && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o spaced ."

[[target]]
name = "plain"
language = "go"
binary = "./plain/plain"
build_cmd = "cd plain && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o plain ."

[comparator]
type = "numeric"
