[campaign]
name = "compare_json_structural"
timeout = "{{or .CampaignTimeout "30m"}}"
exec_timeout = "500ms"
max_input_size = 64

[corpus]
seed_dir = "./seeds"
corpus_dir = "./corpus"
findings_dir = "./findings"

[[target]]
name = "compact"
language = "go"
binary = "./compact/compact"
build_cmd = "cd compact && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o compact ."

[[target]]
name = "reordered"
language = "go"
binary = "./reordered/reordered"
build_cmd = "cd reordered && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o reordered ."

[comparator]
type = "json_structural"
