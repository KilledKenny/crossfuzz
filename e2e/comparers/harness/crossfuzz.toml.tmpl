[campaign]
name = "compare_harness"
timeout = "{{or .CampaignTimeout "30m"}}"
exec_timeout = "500ms"
max_input_size = 64

[corpus]
seed_dir = "./seeds"
corpus_dir = "./corpus"
findings_dir = "./findings"

[[target]]
name = "raw"
language = "go"
binary = "./raw/raw"
build_cmd = "cd raw && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o raw ."

[[target]]
name = "shuffled"
language = "go"
binary = "./shuffled/shuffled"
build_cmd = "cd shuffled && PKGS=$(go list -deps . | grep -vE '^(runtime$|runtime/.*|sync$|sync/.*|internal/.*|reflect$|syscall$|os$|os/.*)' | paste -sd,) && go build -cover -covermode=atomic -coverpkg=\"$PKGS\" -o shuffled ."

[comparator]
type = "harness"
binary = "./comparator/comparator"
build_cmd = "cd comparator && go build -o comparator ."
